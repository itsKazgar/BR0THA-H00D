# ╔══════════════════════════════════════════════════════════════╗
# ║   BR0THER-H00D — Configuration                             ║
# ║   Copy this to .env and fill in what you want              ║
# ║   NOTHING is required — Tier 0 works with empty file       ║
# ╚══════════════════════════════════════════════════════════════╝

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TIER 0 — ZERO CONFIG (works right now)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Rule-based AI scoring. Scans DexScreener, pump.fun,
# CoinGecko. Paper trades automatically. No keys needed.

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TIER 1 — SMARTER AI (free keys, 5 min setup)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Groq — free LLM API (Llama 3, fast)
# Get key: https://console.groq.com
GROQ_API_KEY=

# OpenRouter — access Claude, Gemini, DeepSeek, Grok (free tier)
# Get key: https://openrouter.ai
OPENROUTER_API_KEY=

# Telegram — get trade alerts on your phone
# Get token: message @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TIER 2 — LIVE TRADING (real money, be careful)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Set to true to enable real trades (default: false = paper mode)
LIVE_MODE=false

# Your Solana wallet private key (base58 encoded)
# WARNING: Never share this. Starts with your wallet's secret key.
# Export from Phantom: Settings > Security > Export Private Key
WALLET_PRIVATE_KEY=

# Solana RPC endpoint (default works, upgrade for speed)
# Free upgrade: https://www.helius.dev
SOLANA_RPC=https://api.mainnet-beta.solana.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL UPGRADES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ANTHROPIC_API_KEY=
CEREBRAS_API_KEY=
